// Merge this into Firebase Console > Storage > Rules (don't paste over
// your existing rules blindly, same as firestore.rules).
//
// Lets a logged-in user upload/read only their own banner ad images.
// Nothing here grants "approved" status — that's a Firestore field
// written exclusively by the backend after payment is verified.
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /banner-ads/{uid}/{fileName} {
      allow read: if true; // banner images need to be publicly viewable once shown on-site
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
