// NOT a full ruleset — I don't have access to your live Firebase Console,
// so I can't see your existing rules for watchlist/notifications/etc.
// Do NOT paste this file over your current rules. Instead, open
// Firebase Console > Firestore Database > Rules, and merge ONLY the two
// `match` blocks below into your existing `service cloud.firestore { ... }`
// block, then Publish.
//
// Why these are needed: the whole point of the auto-debit-safe flow is that
// a "Paid"/"active" subscription can only be created by the backend (after
// a verified Razorpay signature) — never by the browser. These rules make
// that a hard guarantee at the database level, not just an assumption in
// the API code.

match /subscriptions/{orderOrSubId} {
  // Users can see their own payment/subscription record...
  allow read: if request.auth != null && request.auth.uid == resource.data.uid;
  // ...but only the backend (Firebase Admin SDK, which bypasses rules
  // entirely) may ever write one. No client write, ever.
  allow write: if false;
}

match /users/{uid} {
  // This app also has a separate `users` collection created by signup()
  // in src/firebase.js using addDoc() with a random doc id (uid stored as
  // a field, not as the doc id). The subscription backend writes a
  // *different* doc: users/{uid} (doc id == uid). They don't conflict,
  // but note there will be two shapes of "users" docs unless you later
  // migrate signup() to use setDoc(doc(db,"users",uid), ...) instead.
  allow read: if request.auth != null && request.auth.uid == uid;
  allow create: if request.auth != null && request.auth.uid == uid
                && !("subscription" in request.resource.data);
  // Clients may update their own doc, but can never set/change the
  // `subscription` field themselves — that would let anyone grant
  // themselves a paid plan from the browser console without paying.
  allow update: if request.auth != null && request.auth.uid == uid
                && request.resource.data.subscription == resource.data.get("subscription", null);
}

match /razorpayPlans/{planId} {
  // Internal cache of Razorpay plan ids — backend only.
  allow read, write: if false;
}

match /adRequests/{orderId} {
  // Same guarantee as /subscriptions: a banner ad request only ever
  // appears here once the backend has verified a real Razorpay payment.
  // No client write, ever — otherwise anyone could submit a "paid" banner
  // request from the browser console without paying.
  allow read: if request.auth != null && request.auth.uid == resource.data.uid;
  allow write: if false;
}
